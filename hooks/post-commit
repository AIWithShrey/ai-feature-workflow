#!/usr/bin/env bash
# post-commit — AI workflow automation hook.
# Delegates to the workflow tools directory (WORKFLOW_TOOLS_DIR).
#
# Set WORKFLOW_TOOLS_DIR in your shell rc or in .git/hooks/env:
#   export WORKFLOW_TOOLS_DIR=/path/to/workflow-tools/scripts

TOOLS_DIR="${WORKFLOW_TOOLS_DIR:-}"

if [[ -z "$TOOLS_DIR" || ! -f "$TOOLS_DIR/config.sh" ]]; then
    # Fail open — never block a commit
    exit 0
fi

COMMIT_SHA=$(git rev-parse HEAD)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
REPO_ROOT="$(git rev-parse --show-toplevel)"

DESIGN_DOCS=()
REVIEW_DOCS=()
CODE_FILES=()
IS_REVIEW_COMMIT=false

while IFS= read -r file; do
    case "$file" in
        # Adjust these patterns to match your repo's design doc location
        docs/*/PROPOSAL_*.md|docs/*/DESIGN_*.md)
            DESIGN_DOCS+=("$REPO_ROOT/$file") ;;
        docs/*/REVIEW_*.md|docs/*/REVIEW_CODE_*.md)
            REVIEW_DOCS+=("$REPO_ROOT/$file")
            IS_REVIEW_COMMIT=true ;;
        *.go|*.ts|*.py|*.yaml|*.yml|*.json)
            CODE_FILES+=("$file") ;;
    esac
done < <(git diff-tree --no-commit-id -r --name-only HEAD)

# Design doc committed → adversarial review
if [[ ${#DESIGN_DOCS[@]} -gt 0 ]]; then
    bash "$TOOLS_DIR/review-design.sh" "${DESIGN_DOCS[@]}" & disown
fi

# Review file committed → apply fixes
if [[ ${#REVIEW_DOCS[@]} -gt 0 ]]; then
    bash "$TOOLS_DIR/apply-code-fixes.sh" "${REVIEW_DOCS[0]}" "$BRANCH" & disown
fi

# Code committed (not a review/fix commit) → code review
if [[ ${#CODE_FILES[@]} -gt 0 && "$IS_REVIEW_COMMIT" == "false" ]]; then
    # Skip loop-guard commit prefixes
    COMMIT_MSG=$(git log -1 --format="%s" HEAD)
    case "$COMMIT_MSG" in
        review:*|"fix: address code review"*|"fix: address Copilot review"*|docs:*|chore:*) exit 0 ;;
    esac
    bash "$TOOLS_DIR/review-code.sh" "$COMMIT_SHA" "$BRANCH" & disown
fi

exit 0
