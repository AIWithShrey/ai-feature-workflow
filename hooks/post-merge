#!/usr/bin/env bash
# post-merge — Rebuild Obsidian KB when landing on main.
TOOLS_DIR="${OTTOFLOW_TOOLS_DIR:-$HOME/Nirmata/ottoflow-workflow-tools/scripts}"

[[ -f "$TOOLS_DIR/config.sh" ]] || exit 0
[[ "$(git rev-parse --abbrev-ref HEAD)" == "main" ]] || exit 0

COMMIT_MSG=$(git log -1 --format="%s" HEAD)
bash "$TOOLS_DIR/explore-repo.sh" "$(git rev-parse --show-toplevel)" "merged to main: $COMMIT_MSG" &
disown
exit 0
